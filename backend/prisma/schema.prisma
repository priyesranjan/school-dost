// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  active
  trial
  suspended
  cancelled
}

enum TenantType {
  school
  college
  coaching
}

enum SubscriptionPlan {
  basic
  standard
  premium
  enterprise
}

enum UserAppRole {
  admin
  accountant
  teacher
  receptionist
  student
  parent
  hod
}

enum UserStatus {
  active
  inactive
}

enum StudentStatus {
  active
  inactive
}

enum AudienceType {
  all
  class
}

enum NoticeStatus {
  draft
  approved
  scheduled
  published
  rejected
}

enum DayOfWeek {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
}

enum PaymentStatus {
  paid
  partial
  unpaid
}

enum PaymentMethod {
  cash
  upi
  bank_transfer
  cheque
}

enum ExpensePaymentMethod {
  cash
  bank_transfer
  cheque
  card
  upi
}

enum LedgerAccountType {
  asset
  liability
  income
  expense
  equity
}

enum BankEntryDirection {
  inflow
  outflow
}

enum AttendanceStatus {
  present
  absent
  late
}

enum SmsLogType {
  payment
  due_reminder
  attendance
  general
  notice
  schedule
  campaign
  otp
}

enum SmsDeliveryStatus {
  pending
  sent
  failed
}

enum DeliveryChannel {
  sms
  whatsapp
}

enum WebhookDeliveryStatus {
  pending
  success
  failed
}

enum PayrollStatus {
  pending
  paid
}

enum PurchaseOrderStatus {
  draft
  approved
  received
  cancelled
}

enum LeaveRequestStatus {
  pending
  approved
  rejected
  cancelled
  completed
}

enum AppraisalStatus {
  draft
  published
}

enum AssignmentWorkflowStatus {
  active
  completed
  archived
}

enum AssignmentSubmissionStatus {
  submitted
  reviewed
  returned
}

enum ClassroomResourceType {
  document
  worksheet
  video
  link
}

enum CertificateType {
  tc
  character
}

enum CertificateStatus {
  issued
  draft
}

enum OtpPurpose {
  login
}

model User {
  id           BigInt      @id @default(autoincrement())
  name         String
  email        String      @unique
  role         UserAppRole
  status       UserStatus  @default(active)
  phone        String?
  passwordHash String?
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  noticesCreated  Notice[]  @relation("NoticeCreatedBy")
  noticesApproved Notice[]  @relation("NoticeApprovedBy")
  noticesRejected Notice[]  @relation("NoticeRejectedBy")
  children        Student[] @relation("ParentToStudent")
  assignmentsCreated    Assignment[]          @relation("AssignmentCreatedBy")
  assignmentSubmissions AssignmentSubmission[]
  leaveRequestsFiled    LeaveRequest[]        @relation("LeaveRequestedBy")
  leaveRequestsApproved LeaveRequest[]        @relation("LeaveApprovedBy")
  appraisalsReviewed    StaffAppraisal[]      @relation("AppraisalReviewedBy")

  @@index([role])
  @@index([status])
}

model Student {
  id              BigInt        @id @default(autoincrement())
  name            String
  firstName       String?
  middleName      String?
  lastName        String?
  rollNumber      String
  className       String
  section         String
  status          StudentStatus @default(active)
  dateOfBirth     DateTime?
  gender          String?
  bloodGroup      String?
  nationality     String?       @default("Indian")
  religion        String?
  category        String?
  caste           String?
  motherTongue    String?
  aadharNumber    String?
  
  enrollmentNo    String?       @unique
  feeNo           String?
  stream          String?
  feeGroup        String?
  academicYear    String?
  admissionDate   DateTime
  dateOfJoining   DateTime?
  
  email           String?
  phone           String?
  
  // Parent / Father Details
  parentName      String
  fatherName      String?
  fatherOccupation String?
  fatherQualification String?
  fatherPhone     String?
  fatherEmail     String?
  fatherAadhar    String?
  fatherAnnualIncome String?
  
  // Mother Details
  motherName      String?
  motherOccupation String?
  motherQualification String?
  motherPhone     String?
  motherEmail     String?
  motherAadhar    String?
  
  // Primary Guardian (legacy fields often mapped to father or separate)
  guardianName    String?
  guardianRelation String?
  guardianPhone   String?
  guardianOccupation String?
  guardianAddress String?
  guardianContacts Json?         // For multiple guardians
  
  // Address Details
  address         String?       @map("address") // legacy mapping
  currentAddress  String?
  currentCity     String?
  currentState    String?
  currentPincode  String?
  currentCountry  String?       @default("India")
  
  permanentAddress String?
  permanentCity    String?
  permanentState   String?
  permanentPincode String?
  permanentCountry String?       @default("India")
  sameAsCurrent    Boolean       @default(false)
  
  // Academic & Previous School
  previousSchool  String?
  previousClass   String?
  tcNumber        String?
  
  // Transport & Medical
  transportMode   String?
  busRoute        String?
  hostelName      String?
  medicalConditions String?
  allergies       String?
  emergencyContactName String?
  emergencyContactPhone String?
  emergencyRelation String?
  
  // Financial & More
  bankName        String?
  bankAccountNo   String?
  ifscCode        String?
  scholarshipName String?
  scholarshipAmount Decimal?     @db.Decimal(12, 2)
  additionalDetails Json?        // For custom fields
  notes           String?       @db.Text
  
  profilePhotoUrl String?
  signatureUrl    String?
  
  parentUserId    BigInt?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  parentUser        User?              @relation("ParentToStudent", fields: [parentUserId], references: [id], onDelete: SetNull)
  feePayments       FeePayment[]
  attendanceRecords AttendanceRecord[]
  certificates      Certificate[]
  examResults       ExamResult[]

  @@unique([rollNumber, className, section])
  @@index([className, section])
  @@index([status])
  @@index([parentUserId])
  @@index([enrollmentNo])
}

model StaffMember {
  id              BigInt   @id @default(autoincrement())
  name            String
  role            String   // teacher, admin, principal, staff
  department      String
  phone           String
  email           String?
  joinDate        DateTime
  status          String   @default("active") // active, on_leave, inactive
  address         String?
  profilePhotoUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payrollProfile PayrollProfile?
  payrollRecords PayrollRecord[]
  leaveRequests  LeaveRequest[]
  appraisals     StaffAppraisal[]
  tasks          StaffTask[]

  @@index([role])
  @@index([department])
  @@index([status])
}

model SchoolClass {
  id            BigInt   @id @default(autoincrement())
  name          String
  grade         Int
  classTeacher  String?
  academicYear  String
  room          String?
  color         String   @default("slate")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sections ClassSection[]

  @@unique([name, academicYear])
  @@index([grade])
  @@index([academicYear])
}

model ClassSection {
  id        BigInt      @id @default(autoincrement())
  classId   BigInt
  name      String
  capacity  Int         @default(40)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  class SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, name])
  @@index([classId])
}

model InstitutionProfile {
  id        Int      @id @default(1)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffTask {
  id          BigInt   @id @default(autoincrement())
  staffId     BigInt
  title       String
  description String?  @db.Text
  priority    String
  status      String   @default("pending")
  dueDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staffMember StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model SecurityPolicy {
  id                      BigInt   @id @default(autoincrement())
  passwordMinLength       Int      @default(8)
  requireUppercase        Boolean  @default(false)
  requireLowercase        Boolean  @default(true)
  requireNumber           Boolean  @default(false)
  requireSpecialChar      Boolean  @default(false)
  sessionTimeoutHours     Int      @default(168)
  allowConcurrentSessions Boolean  @default(true)
  enforceIpAllowlist      Boolean  @default(false)
  ipAllowlist             String[] @default([])
  twoFactorRequiredAdmins Boolean  @default(false)
  updatedByName           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model PayrollProfile {
  id             BigInt   @id @default(autoincrement())
  staffMemberId  BigInt   @unique
  baseSalary     Decimal  @db.Decimal(12, 2)
  allowances     Decimal  @default(0) @db.Decimal(12, 2)
  deductions     Decimal  @default(0) @db.Decimal(12, 2)
  paymentMethod  String?
  bankName       String?
  bankAccountNo  String?
  ifscCode       String?
  panNumber      String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  staffMember    StaffMember    @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  payrollRecords PayrollRecord[]

  @@index([staffMemberId])
}

model PayrollRecord {
  id               BigInt        @id @default(autoincrement())
  staffMemberId     BigInt
  payrollProfileId  BigInt?
  month             DateTime
  baseSalary        Decimal      @db.Decimal(12, 2)
  allowances        Decimal      @default(0) @db.Decimal(12, 2)
  deductions        Decimal      @default(0) @db.Decimal(12, 2)
  grossPay          Decimal      @db.Decimal(12, 2)
  netPay            Decimal      @db.Decimal(12, 2)
  status            PayrollStatus @default(pending)
  paymentReference  String?
  paidAt            DateTime?
  generatedAt       DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  notes             String?      @db.Text

  staffMember       StaffMember     @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  payrollProfile    PayrollProfile? @relation(fields: [payrollProfileId], references: [id], onDelete: SetNull)

  @@unique([staffMemberId, month])
  @@index([month])
  @@index([status])
  @@index([staffMemberId, status])
}

model LeaveRequest {
  id                BigInt            @id @default(autoincrement())
  staffMemberId      BigInt
  requestedByUserId  BigInt?
  approvedByUserId   BigInt?
  leaveType          String
  startDate          DateTime
  endDate            DateTime
  reason             String?          @db.Text
  decisionNote       String?          @db.Text
  status             LeaveRequestStatus @default(pending)
  requestedAt        DateTime         @default(now())
  decidedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  staffMember      StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  requestedByUser  User?       @relation("LeaveRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  approvedByUser   User?       @relation("LeaveApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([staffMemberId])
  @@index([status])
  @@index([startDate, endDate])
  @@index([requestedByUserId])
  @@index([approvedByUserId])
}

model StaffAppraisal {
  id               BigInt          @id @default(autoincrement())
  staffMemberId     BigInt
  reviewerUserId    BigInt?
  reviewPeriod      String
  reviewDate        DateTime
  overallRating     Decimal        @db.Decimal(3, 2)
  strengths         String?        @db.Text
  improvementAreas  String?        @db.Text
  goals             String?        @db.Text
  status            AppraisalStatus @default(draft)
  publishedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  staffMember    StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  reviewerUser   User?       @relation("AppraisalReviewedBy", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([staffMemberId])
  @@index([status])
  @@index([reviewDate])
  @@index([reviewerUserId])
}

model Vendor {
  id           BigInt          @id @default(autoincrement())
  name         String
  contactName  String?
  phone        String?
  email        String?
  address      String?
  gstin        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]

  @@index([name])
}

model InventoryItem {
  id            BigInt              @id @default(autoincrement())
  sku           String              @unique
  name          String
  category      String
  unit          String              @default("unit")
  currentStock  Int                 @default(0)
  reorderLevel  Int                 @default(0)
  unitCost      Decimal?            @db.Decimal(12, 2)
  location      String?
  notes         String?             @db.Text
  vendorId      BigInt?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  vendor             Vendor?              @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  purchaseOrderLines PurchaseOrderLine[]

  @@index([category])
  @@index([currentStock])
  @@index([vendorId])
}

model PurchaseOrder {
  id            BigInt               @id @default(autoincrement())
  poNumber      String               @unique
  vendorId      BigInt
  orderDate     DateTime
  expectedDate  DateTime?
  status        PurchaseOrderStatus  @default(draft)
  totalAmount   Decimal              @db.Decimal(12, 2)
  notes         String?              @db.Text
  approvedAt    DateTime?
  receivedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  vendor Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  lines  PurchaseOrderLine[]

  @@index([vendorId])
  @@index([status])
  @@index([orderDate])
}

model PurchaseOrderLine {
  id               BigInt        @id @default(autoincrement())
  purchaseOrderId  BigInt
  inventoryItemId  BigInt
  quantity         Int
  unitPrice        Decimal       @db.Decimal(12, 2)
  lineTotal        Decimal       @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

model Assignment {
  id              BigInt                   @id @default(autoincrement())
  title           String
  description     String?                  @db.Text
  subject         String
  className       String
  dueDate         DateTime
  resourceUrl     String?
  status          AssignmentWorkflowStatus @default(active)
  teacherName     String?
  createdByUserId BigInt?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  createdByUser User?                  @relation("AssignmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  submissions   AssignmentSubmission[]
  resources     ClassroomResource[]

  @@index([className])
  @@index([subject])
  @@index([status])
  @@index([dueDate])
  @@index([createdByUserId])
}

model ClassroomResource {
  id              BigInt                @id @default(autoincrement())
  title           String
  description     String?               @db.Text
  className       String
  subject         String
  resourceType    ClassroomResourceType
  url             String
  assignmentId    BigInt?
  publishedByName String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([className])
  @@index([subject])
  @@index([resourceType])
  @@index([assignmentId])
}

model AssignmentSubmission {
  id             BigInt                     @id @default(autoincrement())
  assignmentId   BigInt
  userId         BigInt
  userName       String
  userRole       String
  status         AssignmentSubmissionStatus @default(submitted)
  submissionText String?                    @db.Text
  attachmentUrl  String?
  feedback       String?                    @db.Text
  score          Decimal?                   @db.Decimal(5, 2)
  submittedAt    DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
  @@index([status])
  @@index([submittedAt])
}


model FeeStructure {
  id           BigInt   @id @default(autoincrement())
  name         String
  className    String
  amount       Decimal  @db.Decimal(12, 2)
  dueDate      DateTime
  academicYear String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  feePayments FeePayment[]

  @@index([className])
  @@index([academicYear])
}

model FeePayment {
  id             BigInt         @id @default(autoincrement())
  studentId      BigInt
  feeStructureId BigInt?
  totalAmount    Decimal        @db.Decimal(12, 2)
  paidAmount     Decimal        @db.Decimal(12, 2)
  dueAmount      Decimal        @db.Decimal(12, 2)
  status         PaymentStatus
  paymentDate    DateTime?
  paymentMethod  PaymentMethod?
  receiptNumber  String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([status])
  @@index([paymentDate])
}

model Expense {
  id             BigInt               @id @default(autoincrement())
  title          String
  category       String
  amount         Decimal              @db.Decimal(12, 2)
  date           DateTime
  vendorOrStaff  String?
  paymentMethod  ExpensePaymentMethod
  referenceNo    String?
  notes          String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([category])
  @@index([date])
  @@index([paymentMethod])
}

model LedgerAccount {
  id        BigInt            @id @default(autoincrement())
  code      String            @unique
  name      String
  type      LedgerAccountType
  isSystem  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  entries LedgerEntry[]

  @@index([type])
}

model LedgerEntry {
  id          BigInt   @id @default(autoincrement())
  accountId   BigInt
  entryDate   DateTime
  description String
  debit       Decimal  @default(0) @db.Decimal(12, 2)
  credit      Decimal  @default(0) @db.Decimal(12, 2)
  sourceType  String?
  sourceId    String?
  createdAt   DateTime @default(now())

  account LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  bankMatches BankReconciliationEntry[]

  @@index([accountId])
  @@index([entryDate])
  @@index([sourceType, sourceId])
}

model BankAccount {
  id               BigInt   @id @default(autoincrement())
  accountName      String
  bankName         String
  accountNumber    String
  ifscCode         String?
  openingBalance   Decimal  @default(0) @db.Decimal(12, 2)
  notes            String?  @db.Text
  lastReconciledAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reconciliationEntries BankReconciliationEntry[]

  @@index([bankName])
  @@index([accountName])
}

model BankReconciliationEntry {
  id             BigInt             @id @default(autoincrement())
  bankAccountId  BigInt
  ledgerEntryId  BigInt?
  transactionDate DateTime
  description    String
  referenceNo    String?
  amount         Decimal            @db.Decimal(12, 2)
  direction      BankEntryDirection
  matched        Boolean            @default(false)
  notes          String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  bankAccount BankAccount  @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  ledgerEntry LedgerEntry? @relation(fields: [ledgerEntryId], references: [id], onDelete: SetNull)

  @@index([bankAccountId])
  @@index([ledgerEntryId])
  @@index([matched])
  @@index([transactionDate])
}

model AttendanceRecord {
  id        BigInt           @id @default(autoincrement())
  studentId BigInt
  date      DateTime
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
}

model Notice {
  id               BigInt       @id @default(autoincrement())
  title            String
  message          String
  audience         AudienceType
  className        String?
  status           NoticeStatus @default(draft)
  createdById      BigInt?
  approvedById     BigInt?
  rejectedById     BigInt?
  reviewComment    String?
  revisionNo       Int          @default(1)
  approvedTitle    String?
  approvedMessage  String?
  publishAt        DateTime?
  publishedAt      DateTime?
  sendSmsOnPublish Boolean      @default(false)
  smsSent          Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  createdBy  User? @relation("NoticeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedBy User? @relation("NoticeApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy User? @relation("NoticeRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([audience, className])
}

model TimetableEntry {
  id        BigInt    @id @default(autoincrement())
  className String
  day       DayOfWeek
  period    String
  subject   String
  teacher   String
  startTime String
  endTime   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([className, day, period])
  @@index([className, day])
}

model Certificate {
  id            BigInt            @id @default(autoincrement())
  certificateNo String            @unique
  studentId     BigInt
  type          CertificateType
  issueDate     DateTime
  reason        String?
  conduct       String?
  issuedBy      String
  status        CertificateStatus @default(draft)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
}

model AuditLog {
  id               BigInt   @id @default(autoincrement())
  action           String
  module           String
  actorName        String
  actorRole        String
  target           String
  metadata         String
  auditNonce       BigInt?
  prevHash         String
  hash             String
  signatureVersion Int
  createdAt        DateTime @default(now())

  @@index([module])
  @@index([createdAt])
  @@index([auditNonce])
}

model OtpSession {
  id                BigInt     @id @default(autoincrement())
  sessionId         String     @unique
  purpose           OtpPurpose @default(login)
  phone             String
  destinationMasked String
  expiresAt         DateTime
  attempts          Int        @default(0)
  otpCode           String?
  verifiedAt        DateTime?
  createdAt         DateTime   @default(now())

  @@index([phone])
  @@index([expiresAt])
}

model SmsLog {
  id                BigInt            @id @default(autoincrement())
  phone             String
  studentName       String?
  message           String            @db.Text
  type              SmsLogType        @default(general)
  status            SmsDeliveryStatus @default(pending)
  channel           DeliveryChannel   @default(sms)
  templateId        String?
  providerMessageId String?
  providerResponse  Json?
  error             String?
  sentAt            DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([phone])
  @@index([type])
  @@index([status])
  @@index([channel])
  @@index([sentAt])
}

model WebhookSubscription {
  id            BigInt   @id @default(autoincrement())
  name          String
  url           String
  secret        String
  events        String[]
  active        Boolean  @default(true)
  headers       Json?
  timeoutMs     Int      @default(5000)
  failureCount  Int      @default(0)
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([active])
  @@index([lastSuccessAt])
  @@index([lastFailureAt])
}

model WebhookDelivery {
  id             BigInt                 @id @default(autoincrement())
  subscriptionId BigInt
  eventType      String
  attempt        Int                    @default(1)
  status         WebhookDeliveryStatus  @default(pending)
  requestHeaders Json?
  requestBody    Json
  responseStatus Int?
  responseBody   String?
  error          String?
  deliveredAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, createdAt])
  @@index([eventType, createdAt])
  @@index([status])
}

model RefreshToken {
  id          BigInt    @id @default(autoincrement())
  tokenHash   String    @unique
  userSub     String
  name        String
  role        String
  email       String
  sessionId   String?
  userAgent   String?
  ipAddress   String?
  lastSeenAt  DateTime?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userSub, expiresAt])
  @@index([sessionId])
}

enum CalendarEventType {
  holiday
  exam
  event
  pta
  sports
}

model CalendarEvent {
  id          BigInt            @id @default(autoincrement())
  title       String
  date        DateTime
  endDate     DateTime?
  type        CalendarEventType
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([date])
  @@index([type])
}
model Backup {
  id        BigInt   @id @default(autoincrement())
  tenantId  String
  fileName  String
  fileSize  BigInt
  status    String   @default("pending") // pending, success, failed
  error     String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
}

model Exam {
  id           BigInt   @id @default(autoincrement())
  name         String
  className    String
  subject      String
  date         DateTime
  maxMarks     Int
  academicYear String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  results ExamResult[]

  @@index([className])
  @@index([academicYear])
}

model ExamResult {
  id            BigInt   @id @default(autoincrement())
  examId        BigInt
  studentId     BigInt
  marksObtained Int
  grade         String
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([examId])
  @@index([studentId])
}

// ── Platform Tables (Merged) ───────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name    String
  slug    String @unique
  type    TenantType
  board   String?
  logoUrl String?

  city    String
  state   String
  country String @default("India")
  address String?
  pincode String?
  phone   String?

  dbName   String @unique
  dbHost   String @default("localhost")
  dbPort   Int    @default(5432)

  plan               SubscriptionPlan @default(basic)
  status             TenantStatus     @default(trial)
  trialEndsAt        DateTime?
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  monthlyFeeInr      Decimal?         @db.Decimal(10, 2)

  adminName  String
  adminEmail String
  adminPhone String?

  totalStudents Int @default(0)
  totalStaff    Int @default(0)

  institutionCode String @default("001")

  auditLogs TenantAuditLog[]
  backups   Backup[]

  @@index([status])
  @@index([slug])
}

model TenantAuditLog {
  id         BigInt   @id @default(autoincrement())
  createdAt  DateTime @default(now())
  tenantId   String
  action     String
  performedBy String
  details    Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
}

model SuperAdmin {
  id           BigInt   @id @default(autoincrement())
  createdAt    DateTime @default(now())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  lastLoginAt  DateTime?
  isActive     Boolean  @default(true)
  isRoot       Boolean  @default(false)
}
